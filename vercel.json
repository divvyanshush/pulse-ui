{
  "rewrites": [
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/index.html"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/landing-final.html"
    },
    {
      "src": "^/app$",
      "dest": "/index.html"
    },
    {
      "src": "^/app/(.*)$",
      "dest": "/index.html"
    },
    {
      "src": "^/login$",
      "dest": "/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/$1"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.cobunai.com"
        },
        {
          "type": "header",
          "key": "accept",
          "value": "text/html.*"
        }
      ],
      "destination": "https://cobunai.com/:path*",
      "permanent": true
    }
  ]
}